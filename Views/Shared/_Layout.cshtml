<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — UserPanel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #f0f2f5; }
        .navbar { background: #173063 !important; }
        .navbar-brand, .nav-link { color: #d0d0e0 !important; }
        .nav-link:hover { color: #ffffff !important; }
        .card { border: none; border-radius: .75rem; box-shadow: 0 2px 10px rgba(0,0,0,.08); }
        .badge-admin { background: #f59e0b; color: #173063; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">UserPanel</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold" style="color:#f59e0b !important;"
                                   asp-controller="Admin" asp-action="Index">Admin Panel</a>
                            </li>
                        }

                        <li class="nav-item">
                            <span class="nav-link text-secondary small">
                                @User.Identity.Name
                                @if (User.IsInRole("Admin"))
                                {
                                    <span class="badge ms-1 badge-admin">Admin</span>
                                }
                            </span>
                        </li>

                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" style="background-color: #173063; border-color: #173063;" class="btn btn-sm text-white">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a style="background-color: #173063; border-color: #173063;" class="btn btn-sm text-white ms-1" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>